{
  "name": "silverbites",
  "private": true,
  "version": "0.1.0",
  "description": "Silverbites — WhatsApp-native ordering platform for a single restaurant",
  "workspaces": [
    "backend",
    "dashboard"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=backend",
    "dev:dashboard": "npm run dev --workspace=dashboard",
    "build": "npm run build --workspace=backend && npm run build --workspace=dashboard",
    "lint": "npm run lint --workspace=backend && npm run lint --workspace=dashboard",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.15",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.11",
    "pino-pretty": "^11.2.2",
    "prettier": "^3.3.3",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1082.0",
    "@google-cloud/speech": "^7.5.0",
    "@prisma/client": "^6.10.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "prisma": "^6.10.1",
    "zod": "^3.23.8"
  }
}
