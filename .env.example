# ── App ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database (Gate 3) ────────────────────────────────
DATABASE_URL=postgresql://silverbites:silverbites@localhost:5432/silverbites

# ── Redis / Queue (Gate 2) ───────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth (Gate 4) ────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── WhatsApp / Meta Cloud API (Gate 5) ───────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-me-verify-token
WHATSAPP_APP_SECRET=

# ── AI Engine (Gate 7) ───────────────────────────────
ANTHROPIC_API_KEY=

# ── Speech-to-text (Gate 5) ──────────────────────────
OPENAI_API_KEY=

# ── Payments (Gate 8) ────────────────────────────────
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=

# ── Storage (Gate 5/8) ───────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=silverbites-media

# ── Dashboard (Gate 9) ────────────────────────────────
VITE_API_BASE_URL=http://localhost:4000/api
